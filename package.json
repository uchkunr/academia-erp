{
	"name": "academia-erp",
	"description": "Educational Resource Planning (ERP) and Management System built with Bun, Elysia, and Prisma",
	"author": {
		"name": "Uchkun Rakhimov",
		"email": "uchkunrakhimov@gmail.com",
		"url": "https://github.com/uchkunr"
	},
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"start": "bun run dist/src/index",
		"dev": "bun run --watch src/index.ts && tsc-alias",
		"build:bun": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/index.ts",
		"build:node": "tsc --outDir dist && tsc-alias",
		"lint": "eslint --fix . && prettier --write .",
		"test": "bun test",
		"seed": "bun run prisma/seed.ts",
		"db:push": "prisma db push",
		"db:seed": "bun run seed",
		"db:generate": "prisma generate",
		"postinstall": "prisma generate || true"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.2",
		"@elysiajs/jwt": "^1.4.2",
		"@elysiajs/openapi": "^1.4.15",
		"@elysiajs/opentelemetry": "^1.4.11",
		"@elysiajs/server-timing": "^1.4.1",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"axios": "^1.18.1",
		"better-auth": "^1.6.23",
		"dotenv": "^17.4.2",
		"elysia": "1.4.29",
		"pg": "^8.22.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.0.1",
		"bun-types": "1.3.14",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.9.3",
		"prisma": "^7.8.0",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1"
	},
	"module": "src/index.js"
}
